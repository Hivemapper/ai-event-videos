# Beemaps API Key
# Server-side (used by API routes as fallback)
BEEMAPS_API_KEY=your_api_key_here
# Client-side (used by browser, avoids needing to set key in UI)
NEXT_PUBLIC_BEEMAPS_API_KEY=your_api_key_here

# Mapbox Token
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Anthropic API Key
# Server-side (used by API routes as fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Client-side (used by browser, avoids needing to set key in UI)
NEXT_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Turso database used by the VRU and production workers
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Production pipeline S3 destination
PRODUCTION_S3_BUCKET=hivemapper-blurred-ai-event-videos
PRODUCTION_S3_REGION=us-west-2
PRODUCTION_S3_PREFIX=

# AWS credentials can also be provided via ~/.aws/credentials or AWS_PROFILE
AWS_PROFILE=default

# Optional: AWS VRU detector hosts used for queued detection runs.
# If DETECTION_AWS_ASSET_HOSTS is not set, the app tries to discover running
# EC2 instances tagged with names matching vru/detect before syncing local clips.
DETECTION_RUNNER_MODE=aws-queue
DETECTION_AWS_ASSET_HOSTS=
DETECTION_AWS_SSH_USER=ec2-user
DETECTION_AWS_SSH_KEY=~/Downloads/vru.pem
DETECTION_AWS_PROJECT_DIR=/home/ec2-user/ai-event-videos

# Optional: AWS production hosts used for clipped-video production processing.
# If PRODUCTION_AWS_ASSET_HOSTS is not set, the app tries to discover instances
# tagged with fleet=prod-pipeline-fleet before syncing local clips.
PRODUCTION_AWS_ASSET_HOSTS=
PRODUCTION_AWS_SSH_USER=ec2-user
PRODUCTION_AWS_SSH_KEY=~/Downloads/vru.pem
PRODUCTION_AWS_PROJECT_DIR=/home/ec2-user/ai-event-videos
